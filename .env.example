# Copy to .env and fill in values.
# Backend runs with: python manage.py migrate && python manage.py seed_poc && python manage.py runserver
# Optional: if DATABASE_URL is not set, SQLite (db.sqlite3) is used.

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (optional; omit to use SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/assignments

